  "item": [
    {
      "name": "Category APIs",
      "item": [
        {
          "name": "Create Category",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"categoryName\": \"Electronics\",\n    \"displayOrder\": 1,\n    \"description\": \"Electrical devices\",\n    \"iconUrl\": \"https://cdn.com/icon.png\",\n    \"isSubCategory\": \"N\",\n    \"belongToCategory\": null\n}"
            },
            "url": { "raw": "http://localhost:8080/api/categories", "protocol": "http", "host": ["localhost"], "port": "8080", "path": ["api", "categories"] }
          }
        },
        {
          "name": "Get Category By ID",
          "request": {
            "method": "GET",
            "url": "http://localhost:8080/api/categories/1"
          }
        },
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": "http://localhost:8080/api/categories?page=0&size=20"
          }
        },
        {
          "name": "Update Category",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"categoryName\": \"Updated Name\",\n    \"displayOrder\": 2,\n    \"description\": \"Updated description\",\n    \"iconUrl\": \"https://cdn.com/new-icon.png\",\n    \"isSubCategory\": \"Y\",\n    \"belongToCategory\": 1\n}"
            },
            "url": "http://localhost:8080/api/categories/1"
          }
        },
        {
          "name": "Delete Category",
          "request": {
            "method": "DELETE",
            "url": "http://localhost:8080/api/categories/1"
          }
        }
      ]
    },
